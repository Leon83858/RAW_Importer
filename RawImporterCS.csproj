<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>RawImporterCS</AssemblyName>
    <RootNamespace>RawImporterCS</RootNamespace>
    <RuntimeIdentifiers>osx-arm64;osx-x64;win-x64;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.1.3" />
    <PackageReference Include="Avalonia.Desktop" Version="11.1.3" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.1.3" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.1.3" />
    <PackageReference Include="Avalonia.Diagnostics" Version="11.1.3" Condition="'$(Configuration)'=='Debug'" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Colors.axaml" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="RawImporterCS.Tests/**" />
    <EmbeddedResource Remove="RawImporterCS.Tests/**" />
    <None Remove="RawImporterCS.Tests/**" />
  </ItemGroup>
</Project>
